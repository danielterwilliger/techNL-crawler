[Unit]
Description=techNL-crawler dashboard (static server for docs/, Tailscale-reachable)
After=network-online.target
Wants=network-online.target

[Service]
# Serves docs/ on :8088. The public dashboard is on GitHub Pages; this local view
# over Tailscale (http://<tailscale-ip>:8088) is handy for previewing before a push.
# Lock down with: ufw allow in on tailscale0 to any port 8088
User=daniel
WorkingDirectory=/home/daniel/techNL-crawler/docs
ExecStart=/usr/bin/python3 -m http.server 8088 --bind 0.0.0.0
Restart=on-failure

[Install]
WantedBy=multi-user.target
